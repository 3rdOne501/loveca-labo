rules_version = '2';
/*
 * ドンジャラ専用 Firebase プロジェクトの Firestore ルール。
 * （loveca-labo とは別プロジェクト。新規プロジェクトの Firestore に貼り付けて公開）
 */
service cloud.firestore {
  match /databases/{database}/documents {

    /* ラブライブ！ドンジャラ（麻雀準拠）オンライン 4 人卓 */
    match /donjaraRooms/{roomId} {
      /* 認証済みなら読める（ロビーでコード参加するため）。手牌は将来暗号化 or 席別ドキュメント化を検討。 */
      allow read: if request.auth != null;

      /* 作成はホスト本人のみ */
      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid;

      /* 更新はホスト、参加中の席プレイヤー、または空席への着席 */
      allow update: if request.auth != null
        && (
          resource.data.hostUid == request.auth.uid
          || request.auth.uid in resource.data.seatUids
          || (
            resource.data.status in ["waiting", "lobby"]
            && request.auth.uid in request.resource.data.seatUids
          )
        );

      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      /* 席プレイヤーが自分の操作を投函するサブコレクション */
      match /actions/{actionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null; /* ホストが処理後に削除 */
      }
    }

    /* それ以外は既定で拒否 */
  }
}
