rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    /** 匿名（ゲスト）を除く Google ログイン */
    function isGoogleSignedIn() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isPublicDeckPayloadValid() {
      return request.resource.data.keys().hasAll([
          'v', 'name', 'note', 'deck', 'keyCardNos', 'keyCard2Nos', 'keyCard3Nos',
          'middleCardNos', 'thumbnailCardNo', 'ownerUid', 'ownerName', 'ownerPhotoURL',
          'createdAt', 'updatedAt'
        ])
        && request.resource.data.v is int
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 400
        && request.resource.data.deck is map
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    match /users/{userId}/state/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /versusMatches/{roomId} {
      /* ホスト・ゲスト、または空き席があるルーム（参加前の getDoc 用） */
      allow read: if isSignedIn()
        && (
          resource.data.hostUid == request.auth.uid
          || resource.data.guestUid == request.auth.uid
          || (
            resource.data.guestUid == null
            && resource.data.status in ["waiting", "lobby"]
          )
        );

      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid;

      /* ホスト／既参加ゲストの更新、または初回参加（guestUid を自分にセット） */
      allow update: if isSignedIn()
        && (
          resource.data.hostUid == request.auth.uid
          || resource.data.guestUid == request.auth.uid
          || (
            resource.data.guestUid == null
            && request.resource.data.guestUid == request.auth.uid
            && request.resource.data.hostUid == resource.data.hostUid
            && resource.data.status in ["waiting", "lobby"]
          )
        );

      allow delete: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;
    }

    /* コミュニティ投稿デッキ: 閲覧は誰でも、投稿/削除は Google ログインの本人のみ */
    match /publicDecks/{deckId} {
      allow read: if true;

      allow create: if isGoogleSignedIn()
        && isPublicDeckPayloadValid();

      allow update: if isGoogleSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && isPublicDeckPayloadValid()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isGoogleSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
